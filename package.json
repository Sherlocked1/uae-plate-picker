{
  "name": "@sherlocked1/uae-plate-picker",
  "version": "0.1.0",
  "description": "React component library for UAE private license plate selection and preview",
  "type": "module",
  "license": "MIT",
  "author": "Sherlocked1",
  "keywords": [
    "react",
    "uae",
    "license-plate",
    "plate-picker",
    "emirates"
  ],
  "homepage": "https://github.com/Sherlocked1/uae-plate-picker#readme",
  "bugs": "https://github.com/Sherlocked1/uae-plate-picker/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sherlocked1/uae-plate-picker.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -p tsconfig.build.json && vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "prepublishOnly": "pnpm build",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.9",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-dts": "^5.0.3"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
